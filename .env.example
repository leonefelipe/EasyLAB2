# ─────────────────────────────────────────────────────────────────────────────
# EasyLAB2 — Environment configuration
# Copy this file to `.env` and fill in values.
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API key (REQUIRED).
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI API base URL (optional).
# Only set this if you use a compatible proxy (e.g. OpenRouter, Azure OpenAI).
# Default: https://api.openai.com
# OPENAI_API_BASE_URL=https://api.openai.com

# Primary model used for all analysis calls (optional).
# Default: gpt-4o  — best structured-output support.
# You can set to gpt-4o-mini to reduce cost during development.
# OPENAI_MODEL=gpt-4o

# Cheap model used by server/_core/llm.ts → repairJson() to automatically
# repair broken JSON returned by the primary model (Phase A / task A3).
# Optional — Default: gpt-4o-mini.
# OPENAI_REPAIR_MODEL=gpt-4o-mini

# HTTP port (optional). Default: 3000
# PORT=3000

# MySQL connection string.
# Required only when CRM features (clients/projects) move off localStorage
# in Fase 1. Leave empty in Fase 0/A.
# Example: mysql://user:password@host:3306/easylab2
# DATABASE_URL=

# CORS origin (optional). Default: *
# Restrict in production if exposing the API publicly.
# CORS_ORIGIN=*

# Node environment (auto-set by Render/Vercel; rarely needs manual override).
# NODE_ENV=development